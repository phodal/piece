{
  "name": "piece-compiler",
  "version": "0.1.0",
  "description": "Piece-aware build feedback for AI-era coding agents.",
  "type": "module",
  "types": "./src/public-api/index.d.ts",
  "bin": {
    "piece": "./bin/piece.js"
  },
  "license": "Apache-2.0",
  "sideEffects": [
    "./src/index.js",
    "./src/browser.js",
    "./src/node.js",
    "./src/public-api/index.js",
    "./src/public-api/browser.js",
    "./src/public-api/node.js"
  ],
  "homepage": "https://phodal.github.io/piece/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phodal/piece.git"
  },
  "bugs": {
    "url": "https://github.com/phodal/piece/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:cli": "vitest run test/cli.test.js",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm pack --dry-run",
    "smoke:packed": "node scripts/smoke-packed-package.mjs",
    "go:check": "cd go-backend && go test ./...",
    "language:verify": "npm run go:check && npm run core:check && npm run pic:dsl:smoke && npm run pic:kotlin:smoke && npm run pic:source:smoke && npm run pic:override:smoke && npm run language:analysis:smoke && npm run language:analysis-api-gate:smoke && npm run language:analysis-api:smoke && npm run language:project-model:smoke && npm run language:compile:smoke",
    "release:verify": "npm run verify && npm run smoke:packed && npm run language:verify",
    "prepublishOnly": "npm run release:verify",
    "core:check": "node scripts/run-gradle.mjs check wasmJsBrowserDistribution jsNodeProductionLibraryDistribution && node scripts/smoke-kotlin-core-bridge.mjs",
    "core:js:build": "node scripts/run-gradle.mjs jsNodeProductionLibraryDistribution",
    "core:bridge:smoke": "npm run core:js:build && node scripts/smoke-kotlin-core-bridge.mjs",
    "core:wasm:build": "node scripts/run-gradle.mjs wasmJsBrowserDistribution",
    "pic:dsl:smoke": "node scripts/smoke-pic-dsl.mjs",
    "pic:kotlin:smoke": "node scripts/smoke-kotlin-pic-dsl.mjs",
    "pic:source:smoke": "node scripts/smoke-source-pic-dsl.mjs",
    "pic:override:smoke": "node scripts/smoke-pic-override-merge.mjs",
    "language:analysis:smoke": "node scripts/smoke-kotlin-psi-analysis.mjs",
    "language:analysis-api-gate:smoke": "node scripts/run-gradle.mjs checkKotlinAnalysisApiGate",
    "language:analysis-api:smoke": "node scripts/smoke-kotlin-analysis-api.mjs",
    "language:project-model:smoke": "node scripts/smoke-kotlin-gradle-project-model.mjs",
    "language:compile:smoke": "node scripts/smoke-language-compilers.mjs",
    "benchmark:kotlin-piece": "node scripts/benchmark-kotlin-piece.mjs",
    "benchmark:workspace-session": "node scripts/benchmark-workspace-session.mjs",
    "preview:build": "node preview/build.mjs",
    "preview": "npm run preview:build && node preview/serve.mjs",
    "pages:build": "npm run preview:build && npm run core:wasm:build && node scripts/build-pages.mjs",
    "sites:build": "npm run pages:build && node scripts/build-sites.mjs"
  },
  "keywords": [
    "go",
    "kotlin",
    "react",
    "typescript",
    "compiler",
    "piece-aware-build",
    "feedback-graph",
    "incremental-build",
    "editor-tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./src/public-api/index.d.ts",
      "import": "./src/public-api/index.js"
    },
    "./browser": {
      "types": "./src/public-api/browser.d.ts",
      "import": "./src/public-api/browser.js"
    },
    "./node": {
      "types": "./src/public-api/node.d.ts",
      "import": "./src/public-api/node.js"
    },
    "./testing": {
      "types": "./src/public-api/testing.d.ts",
      "import": "./src/public-api/testing.js"
    }
  },
  "files": [
    "CHANGELOG.md",
    "SECURITY.md",
    "bin",
    "docs",
    "go-backend",
    "grammar",
    "gradlew",
    "gradlew.bat",
    "piece-core/README.md",
    "piece-core/build.gradle.kts",
    "piece-core/settings.gradle.kts",
    "piece-core/gradle/wrapper/gradle-wrapper.jar",
    "piece-core/gradle/wrapper/gradle-wrapper.properties",
    "piece-core/gradlew",
    "piece-core/gradlew.bat",
    "piece-core/src",
    "scripts",
    "src"
  ],
  "dependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@types/node": "^24.0.10",
    "codemirror": "^6.0.2",
    "esbuild-wasm": "^0.28.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vitest": "^4.1.10"
  }
}
